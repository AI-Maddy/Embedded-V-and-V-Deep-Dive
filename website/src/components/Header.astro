---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <a href="/" class="brand">🔬 {SITE_TITLE}</a>
    <div class="nav-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
  </nav>
</header>

<style>
  header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(7,9,15,.92);
    border-bottom: 1px solid rgba(108,99,255,.15);
    backdrop-filter: blur(14px);
    padding: 0 1.5rem;
  }
  nav {
    display: flex; align-items: center;
    justify-content: space-between;
    max-width: 1100px; margin: 0 auto;
    height: 56px;
  }
  .brand {
    font-weight: 800; font-size: .95rem; text-decoration: none;
    background: linear-gradient(90deg, #e2e8f0, #a29bfe);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    transition: opacity .2s;
  }
  .brand:hover { opacity: .85; }
  .nav-links { display: flex; gap: .25rem; align-items: center; }
  .nav-links :global(a) {
    padding: .45rem .8rem; border-radius: 8px;
    color: #4a5568; text-decoration: none;
    font-size: .85rem; font-weight: 500;
    transition: color .2s, background .2s;
    border-bottom: none !important;
  }
  .nav-links :global(a:hover) { color: #e2e8f0; background: rgba(108,99,255,.1); }
  .nav-links :global(a.active) { color: #a29bfe; background: rgba(108,99,255,.12); }
</style>
